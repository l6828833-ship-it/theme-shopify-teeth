<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="icon" type="image/png" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">
  <link rel="shortcut icon" type="image/png" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">
  <link rel="apple-touch-icon" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">

  {% if template == 'index' %}
    <title>Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips.com</title>
    <meta name="description" content="Get the best teeth whitening strips that actually work. 3DWhiteningStrips delivers a visibly whiter smile in just 7 days — enamel-safe, dentist-recommended whitening strips with zero sensitivity. Free shipping &amp; 7-day money-back guarantee.">
    <link rel="canonical" href="https://3dwhiteningstrips.com/">
    <meta property="og:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta property="og:description" content="Shop the best teeth whitening strips from 3DWhiteningStrips. Enamel-safe, dentist-recommended whitening strips with visible results in 7 days.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://3dwhiteningstrips.com/">
    <meta property="og:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta name="twitter:description" content="The best teeth whitening strips for a whiter smile in 7 days. Enamel-safe, dentist-recommended whitening strips from 3DWhiteningStrips.">
    <meta name="twitter:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
  {% else %}
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  <meta name="keywords" content="whitening strips, teeth whitening strips, best whitening strips, recommended whitening strips, best teeth whitening strips, do whitening strips work, 3dwhiteningstrips, 3dwhiteningstrips.com">
  <meta name="robots" content="index, follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="shopify-section" id="shopify-section-header">
    {{ content_for_header }}
  </div>

  <nav class="navbar">
    <div class="container">
      <button class="nav-toggle" id="navToggle" type="button" aria-label="Open menu"><span></span><span></span><span></span></button>
      <a href="/" class="logo" aria-label="3DWhiteningStrips home">
        <img src="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/3dwhiteningstrips%20logo.png" alt="3DWhiteningStrips teeth whitening strips logo" class="logo-img">
      </a>
      <ul class="nav-menu" id="navMenu">
        {% if linklists.main-menu.links.size > 0 %}
          {% for link in linklists.main-menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        {% else %}
          <li><a href="/">{{ 'nav.home' | t }}</a></li>
          <li><a href="/collections/all">{{ 'nav.shop' | t }}</a></li>
          <li><a href="/pages/faq">{{ 'nav.faq' | t }}</a></li>
          <li><a href="/pages/about-us">{{ 'nav.about' | t }}</a></li>
          <li><a href="/pages/contact">{{ 'nav.contact' | t }}</a></li>
        {% endif %}
      </ul>
      <div class="nav-actions">
        <a href="/collections/all" class="btn btn-primary nav-shop-btn">{{ 'general.shop' | t }}</a>
      </div>
    </div>
  </nav>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <footer role="contentinfo" class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-section footer-intro">
          <h3>3DWhiteningStrips</h3>
          <p>{{ 'footer.intro' | t }}</p>
          <ul class="footer-contact">
            <li>✉️ <a href="mailto:camilasousa@duck.com">camilasousa@duck.com</a></li>
            <li>📞 <a href="tel:920715535">920715535</a></li>
            <li>🚚 {{ 'footer.shipping_line' | t }}</li>
          </ul>
          {% form 'localization' %}
            <div class="footer-lang">
              {{ form.language_html | default: '' }}
              <select name="locale_code" onchange="this.form.submit()" aria-label="Language">
                {% for language in localization.available_languages %}
                  <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>{{ language.endonym_name | capitalize }}</option>
                {% endfor %}
              </select>
            </div>
          {% endform %}
        </div>
        <div class="footer-section">
          <h4>{{ 'footer.col_shop' | t }}</h4>
          <ul>
            <li><a href="/collections/all">{{ 'footer.shop_all' | t }}</a></li>
            <li><a href="/#pricing">{{ 'footer.pricing' | t }}</a></li>
            <li><a href="/#how-it-works">{{ 'footer.how' | t }}</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>{{ 'footer.col_company' | t }}</h4>
          <ul>
            <li><a href="/pages/about-us">{{ 'footer.about' | t }}</a></li>
            <li><a href="/pages/contact">{{ 'footer.contact' | t }}</a></li>
            <li><a href="/pages/faq">{{ 'nav.faq' | t }}</a></li>
            <li><a href="/pages/product-safety">{{ 'footer.product_safety' | t }}</a></li>
            <li><a href="/blogs/news">{{ 'footer.blog' | t }}</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>{{ 'footer.col_legal' | t }}</h4>
          <ul>
            <li><a href="/pages/shipping-policy">{{ 'footer.shipping_policy' | t }}</a></li>
            <li><a href="/pages/refund-policy">{{ 'footer.refund_policy' | t }}</a></li>
            <li><a href="/pages/privacy-policy">{{ 'footer.privacy_policy' | t }}</a></li>
            <li><a href="/pages/cookie-policy">{{ 'footer.cookie_policy' | t }}</a></li>
            <li><a href="/pages/terms-of-service">{{ 'footer.terms' | t }}</a></li>
            <li><a href="/pages/disclaimer">{{ 'footer.disclaimer' | t }}</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {{ "now" | date: "%Y" }} 3DWhiteningStrips.com. {{ 'footer.rights' | t }} · <a href="mailto:camilasousa@duck.com">camilasousa@duck.com</a> · 920715535</p>
      </div>
    </div>
  </footer>

  {%- assign fb_product = all_products['3dwhiteningstrips-teeth-whitening-strips'] -%}
  {%- if fb_product == blank -%}{%- assign fb_product = collections.all.products.first -%}{%- endif -%}
  {%- assign fb_v1 = fb_product.variants.first -%}
  {%- for fbv in fb_product.variants -%}{%- if fbv.title contains '1 Box' -%}{%- assign fb_v1 = fbv -%}{%- endif -%}{%- endfor -%}
  <div class="flash-bar" id="flashBar" role="region" aria-label="Limited time offer">
    <div class="flash-bar-inner">
      <span class="flash-bar-icon">🔥</span>
      <div class="flash-bar-text">
        <strong>{{ 'flash.title' | t }}</strong>
        <span class="flash-bar-price">
          {% if fb_v1.compare_at_price > fb_v1.price %}<span class="flash-old">{{ fb_v1.compare_at_price | money }}</span>{% endif %}
          <span class="flash-arrow">→</span>
          <span class="flash-new">{{ fb_v1.price | money }}</span>
        </span>
      </div>
      <div class="flash-timer flash-bar-timer" id="flashTimer" aria-label="Offer countdown timer">
        <span class="timer-num" data-unit="hours">00</span><span class="timer-colon">:</span><span class="timer-num" data-unit="minutes">00</span><span class="timer-colon">:</span><span class="timer-num" data-unit="seconds">00</span>
      </div>
      <a href="/products/3dwhiteningstrips-teeth-whitening-strips" class="flash-bar-cta">{{ 'general.claim_offer' | t }}</a>
      <button class="flash-bar-close" id="flashBarClose" type="button" aria-label="Dismiss offer">✕</button>
    </div>
  </div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
