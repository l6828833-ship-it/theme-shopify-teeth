<!DOCTYPE html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {% if template == 'index' %}
    <title>Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips.com</title>
    <meta name="description" content="3DWhiteningStrips.com offers the best teeth whitening strips — dentist-recommended, enamel-safe whitening strips for a whiter smile in 7 days. Do whitening strips work? Ours do. Free shipping &amp; 30-day guarantee.">
    <link rel="canonical" href="https://3dwhiteningstrips.com/">
    <meta property="og:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta property="og:description" content="Shop the best teeth whitening strips from 3DWhiteningStrips. Enamel-safe, dentist-recommended whitening strips with visible results in 7 days.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://3dwhiteningstrips.com/">
    <meta property="og:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta name="twitter:description" content="The best teeth whitening strips for a whiter smile in 7 days. Enamel-safe, dentist-recommended whitening strips from 3DWhiteningStrips.">
    <meta name="twitter:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
  {% else %}
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  <meta name="keywords" content="whitening strips, teeth whitening strips, best whitening strips, recommended whitening strips, best teeth whitening strips, do whitening strips work, 3dwhiteningstrips, 3dwhiteningstrips.com">
  <meta name="robots" content="index, follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {% if template == 'index' %}
    {{ 'home.css' | asset_url | stylesheet_tag }}
  {% endif %}
</head>
<body>
  <div class="shopify-section" id="shopify-section-header">
    {{ content_for_header }}
  </div>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <footer role="contentinfo" class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-section">
          <h3>3DWhiteningStrips</h3>
          <p>The best teeth whitening strips for modern smiles — dentist-recommended whitening strips from 3DWhiteningStrips.com.</p>
        </div>
        <div class="footer-section">
          <h4>Product</h4>
          <ul>
            <li><a href="#how-it-works">How It Works</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#testimonials">Reviews</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Company</h4>
          <ul>
            <li><a href="#">About</a></li>
            <li><a href="#">Contact</a></li>
            <li><a href="#">Blog</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Legal</h4>
          <ul>
            <li><a href="#">Privacy</a></li>
            <li><a href="#">Terms</a></li>
            <li><a href="#">Returns</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {{ "now" | date: "%Y" }} 3DWhiteningStrips.com. All rights reserved. The best teeth whitening strips online.</p>
      </div>
    </div>
  </footer>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
