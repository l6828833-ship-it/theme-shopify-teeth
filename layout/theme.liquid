<!DOCTYPE html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="icon" type="image/png" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">
  <link rel="shortcut icon" type="image/png" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">
  <link rel="apple-touch-icon" href="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/logo%203dwhiteningstrips.png">

  {% if template == 'index' %}
    <title>Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips.com</title>
    <meta name="description" content="Get the best teeth whitening strips that actually work. 3DWhiteningStrips delivers a visibly whiter smile in just 7 days — enamel-safe, dentist-recommended whitening strips with zero sensitivity. Free shipping &amp; 7-day money-back guarantee.">
    <link rel="canonical" href="https://3dwhiteningstrips.com/">
    <meta property="og:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta property="og:description" content="Shop the best teeth whitening strips from 3DWhiteningStrips. Enamel-safe, dentist-recommended whitening strips with visible results in 7 days.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://3dwhiteningstrips.com/">
    <meta property="og:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Best Whitening Strips &amp; Teeth Whitening Strips | 3DWhiteningStrips">
    <meta name="twitter:description" content="The best teeth whitening strips for a whiter smile in 7 days. Enamel-safe, dentist-recommended whitening strips from 3DWhiteningStrips.">
    <meta name="twitter:image" content="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png">
  {% else %}
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  <meta name="keywords" content="whitening strips, teeth whitening strips, best whitening strips, recommended whitening strips, best teeth whitening strips, do whitening strips work, 3dwhiteningstrips, 3dwhiteningstrips.com">
  <meta name="robots" content="index, follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <div class="shopify-section" id="shopify-section-header">
    {{ content_for_header }}
  </div>

  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo" aria-label="3DWhiteningStrips home">
        <img src="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/3dwhiteningstrips%20logo.png" alt="3DWhiteningStrips teeth whitening strips logo" class="logo-img">
      </a>
      <a href="/collections/all" class="btn btn-primary">Shop Whitening Strips</a>
    </div>
  </nav>

  <main role="main">
    {{ content_for_layout }}
  </main>

  <footer role="contentinfo" class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-section">
          <h3>3DWhiteningStrips</h3>
          <p>The best teeth whitening strips for modern smiles — dentist-recommended whitening strips from 3DWhiteningStrips.com.</p>
        </div>
        <div class="footer-section">
          <h4>Product</h4>
          <ul>
            <li><a href="#how-it-works">How It Works</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#testimonials">Reviews</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Company</h4>
          <ul>
            <li><a href="#">About</a></li>
            <li><a href="#">Contact</a></li>
            <li><a href="#">Blog</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Legal</h4>
          <ul>
            <li><a href="#">Privacy</a></li>
            <li><a href="#">Terms</a></li>
            <li><a href="#">Returns</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {{ "now" | date: "%Y" }} 3DWhiteningStrips.com. All rights reserved. The best teeth whitening strips online.</p>
      </div>
    </div>
  </footer>

  <div class="flash-bar" id="flashBar" role="region" aria-label="Limited time offer">
    <div class="flash-bar-inner">
      <span class="flash-bar-icon">🔥</span>
      <div class="flash-bar-text">
        <strong>Today Only — 67% Off Whitening Strips</strong>
        <span class="flash-bar-price">
          <span class="flash-old"><span class="price-amount" data-amount="29.99"></span></span>
          <span class="flash-arrow">→</span>
          <span class="flash-new"><span class="flash-symbol"></span><span class="flash-num" data-from="29.99" data-to="9.99">29.99</span></span>
        </span>
      </div>
      <div class="flash-timer flash-bar-timer" id="flashTimer" aria-label="Offer countdown timer">
        <span class="timer-num" data-unit="hours">00</span><span class="timer-colon">:</span><span class="timer-num" data-unit="minutes">00</span><span class="timer-colon">:</span><span class="timer-num" data-unit="seconds">00</span>
      </div>
      <a href="/products/3dwhiteningstrips-teeth-whitening-strips" class="flash-bar-cta">Claim 67% Off</a>
      <button class="flash-bar-close" id="flashBarClose" type="button" aria-label="Dismiss offer">✕</button>
    </div>
  </div>

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
