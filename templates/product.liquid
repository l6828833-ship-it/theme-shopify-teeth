{%- assign img_product = product.featured_image | default: 'https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips%20(4)%20(1).png' -%}

<!-- Offers marquee bar -->
<div class="offers-bar">
  <div class="offers-track">
    <span>🔥 67% OFF TODAY</span>
    <span>🚚 FREE WORLDWIDE SHIPPING</span>
    <span>🛡️ 7-DAY MONEY-BACK GUARANTEE</span>
    <span>✨ VISIBLE RESULTS IN 7 DAYS</span>
    <span>🦷 ENAMEL-SAFE FORMULA</span>
    <span>🔥 67% OFF TODAY</span>
    <span>🚚 FREE WORLDWIDE SHIPPING</span>
    <span>🛡️ 7-DAY MONEY-BACK GUARANTEE</span>
    <span>✨ VISIBLE RESULTS IN 7 DAYS</span>
    <span>🦷 ENAMEL-SAFE FORMULA</span>
  </div>
</div>

<!-- PDP Hero -->
<section class="pdp-hero">
  <div class="pdp-blob pdp-blob-1"></div>
  <div class="pdp-blob pdp-blob-2"></div>
  <div class="container">
    <div class="pdp-grid">
      <!-- Left: content + offer selector -->
      <div class="pdp-content">
        <div class="pdp-eyebrow">✓ Dentist Recommended Whitening Strips</div>
        <h1>{{ product.title }}</h1>
        <p class="pdp-sub">Professional-grade, enamel-safe teeth whitening strips that lift years of coffee, tea, and wine stains for a visibly whiter smile in just 7 days — no sensitivity, no dentist bill.</p>

        <div class="pdp-rating">
          <div class="pdp-stars">
            <svg class="star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="star" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <span class="pdp-rating-label">Enamel-safe &amp; dentist-recommended formula</span>
        </div>

        <div class="pdp-urgency">🔥 Last 48 hours of this week's free shipping offer</div>

        <p class="pdp-choose">Choose your package:</p>
        {% form 'product', product %}
          <div class="pdp-options">
            {% for variant in product.variants %}
              <label class="pdp-option{% if forloop.first %} selected{% endif %}">
                <input type="radio" name="id" value="{{ variant.id }}" data-price="{{ variant.price | money }}" {% if forloop.first %}checked{% endif %}>
                <span class="pdp-option-radio"></span>
                <span class="pdp-option-main">
                  <span class="pdp-option-title">{{ variant.title }}</span>
                  <span class="pdp-option-detail">
                    {%- case forloop.index -%}
                      {%- when 1 -%}14 strips · 7-day treatment
                      {%- when 2 -%}28 strips · 14-day treatment
                      {%- when 3 -%}42 strips · 21-day treatment
                      {%- else -%}{{ variant.title }}
                    {%- endcase -%}
                  </span>
                </span>
                <span class="pdp-option-price">
                  {% if variant.compare_at_price > variant.price %}<span class="pdp-option-was">{{ variant.compare_at_price | money }}</span>{% endif %}
                  <span class="pdp-option-now">{{ variant.price | money }}</span>
                </span>
                {% if forloop.index == 2 %}<span class="pdp-option-badge popular">Most Popular</span>{% endif %}
                {% if forloop.index == 3 %}<span class="pdp-option-badge best">Best Value</span>{% endif %}
              </label>
            {% endfor %}
          </div>

          <div class="pdp-add-wrap">
            <button type="submit" name="add" class="cta-button pdp-add" id="pdpCta"{% unless product.available %} disabled{% endunless %}>
              {% if product.available %}<span id="pdpBtnLabel">Order Now — {{ product.selected_or_first_available_variant.price | money }}</span>{% else %}Sold Out{% endif %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 1.25rem; height: 1.25rem;">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
            <span class="cta-discount-tag" id="pdpTag" aria-hidden="true">-67%</span>
          </div>
        {% endform %}

        <p class="pdp-paynote">🔒 Secure checkout · Free worldwide shipping · 7-day money-back guarantee</p>
      </div>

      <!-- Right: image + trust badges -->
      <div class="pdp-media">
        <div class="pdp-image">
          <div class="pdp-glow"></div>
          <img id="pdpMainImage" src="{{ img_product | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}">
        </div>
        {% if product.images.size > 1 %}
          <div class="pdp-thumbs">
            {% for image in product.images %}
              <button type="button" class="pdp-thumb" onclick="document.getElementById('pdpMainImage').src='{{ image | image_url: width: 800 }}'">
                <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape | default: product.title }}">
              </button>
            {% endfor %}
          </div>
        {% endif %}
        <div class="pdp-trust-badges">
          <div class="pdp-trust"><strong>Enamel Safe</strong><span>Gentle formula</span></div>
          <div class="pdp-trust"><strong>Dentist</strong><span>Recommended</span></div>
          <div class="pdp-trust"><strong>7 Days</strong><span>To results</span></div>
          <div class="pdp-trust"><strong>14</strong><span>Strips per box</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Slide-in offer notification that docks onto the Order Now button -->
  <div class="hero-notification" id="pdpNotification" role="status" aria-live="polite">
    <div class="hero-notif-icon">🔥</div>
    <div class="hero-notif-body">
      <div class="hero-notif-line">Flash Sale: now <strong class="hero-notif-now">{{ product.price | money }}</strong></div>
      <div class="hero-notif-was">{{ product.compare_at_price | money }}</div>
    </div>
  </div>
</section>

<!-- Before & After -->
<section class="before-after">
  <div class="container">
    <div class="section-header">
      <h2>See the Transformation</h2>
      <p>Real results from a single treatment cycle with our teeth whitening strips</p>
    </div>
    <div class="comparison-image">
      <img src="https://d2xsxph8kpxj0f.cloudfront.net/310519663743569624/amyPSPrF2HUmPeJK9rK5RK/before-after-comparison-X9GBvVf2LvMU5MUHgjePtJ.webp" alt="Before and after results using 3DWhiteningStrips teeth whitening strips">
    </div>
  </div>
</section>

