  <div class="container">
    <div class="section-header">
      <h2>How It Works</h2>
      <p>A brighter smile in three effortless steps — just 30 minutes a day</p>
    </div>
    <div class="steps-grid">
      <div class="step-card">
        <span class="step-line"></span>
        <div class="step-icon-ring"><span class="step-emoji">🦷</span><span class="step-number">1</span></div>
        <h3>Apply Strips</h3>
        <p>Peel and press a strip onto your upper and lower teeth.</p>
        <span class="step-meta">⏱️ 30 seconds</span>
      </div>
      <div class="step-card">
        <span class="step-line"></span>
        <div class="step-icon-ring"><span class="step-emoji">😌</span><span class="step-number">2</span></div>
