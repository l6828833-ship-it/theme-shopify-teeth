  <div class="container">
    <div class="feature-grid">
      <div class="feature-visual">
        <div class="feature-glow"></div>
        <img src="https://pub-1271a678a52f4664aa377c2be4276e07.r2.dev/teeth%20whitening%20strips.png" alt="3DWhiteningStrips whitening strips kit and formula">
      </div>
      <div class="feature-content">
        <div class="hero-badge">What's Inside</div>
        <h2>A Formula Built for <span class="highlight">Real, Gentle Results</span></h2>
