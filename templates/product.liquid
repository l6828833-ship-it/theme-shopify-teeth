<!-- FAQ -->
<section class="faq">
  <div class="container">
    <div class="section-header"><h2>Frequently Asked Questions</h2></div>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-question active" onclick="toggleFaq(this)"><span>Do whitening strips work?</span><svg class="faq-toggle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <div class="faq-answer open"><p>Yes — our enamel-safe strips deliver whitening gel directly to your teeth to break down stains, with a visibly whiter smile after a single 7-day treatment.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)"><span>Are they safe for sensitive teeth?</span><svg class="faq-toggle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <div class="faq-answer"><p>Yes. Our balanced, enamel-safe formula is designed to minimize sensitivity. If you have dental concerns, review our Product Safety page or consult your dentist.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="toggleFaq(this)"><span>How fast is shipping?</span><svg class="faq-toggle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
        <div class="faq-answer"><p>Free worldwide shipping on every order, typically arriving within 6–10 days.</p></div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var options = document.querySelectorAll('.pdp-option input[type="radio"]');
    var label = document.getElementById('pdpBtnLabel');
    var mainImg = document.getElementById('pdpMainImage');
    options.forEach(function (input) {
      input.addEventListener('change', function () {
        document.querySelectorAll('.pdp-option').forEach(function (l) { l.classList.remove('selected'); });
        var lbl = input.closest('.pdp-option');
        if (lbl) lbl.classList.add('selected');
        if (label) label.textContent = 'Order Now — ' + input.getAttribute('data-price');
      });
    });
  })();
</script>
