<section class="listing-page">
  <div class="container">
    <div class="section-header">
      <h1>Search</h1>
    </div>

    <form action="/search" method="get" role="search" class="search-form">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search whitening strips..." aria-label="Search">
      <button type="submit" class="cta-button">Search</button>
    </form>

    {% if search.performed %}
      {% if search.results.size > 0 %}
        <div class="product-grid">
          {% for item in search.results %}
            <a href="{{ item.url }}" class="product-card">
              <div class="product-card-img">
                {% if item.featured_image %}
                  <img src="{{ item.featured_image | image_url: width: 500 }}" alt="{{ item.title | escape }}">
                {% endif %}
              </div>
              <h3>{{ item.title }}</h3>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p class="search-empty">No results found for "{{ search.terms | escape }}". Try another search.</p>
      {% endif %}
    {% endif %}
  </div>
</section>
