<section class="static-page">
  <div class="container static-narrow" style="text-align:center;">
    <div class="section-header"><h1>Taking you to checkout…</h1></div>
    <a href="/checkout" class="cta-button">Continue to Checkout</a>
  </div>
</section>

<script>
  // This store skips the cart page entirely — go straight to checkout if there
  // are items, otherwise back to the homepage to choose a package.
  (function () {
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        window.location.replace(cart.item_count > 0 ? '/checkout' : '/');
      })
      .catch(function () { window.location.replace('/'); });
  })();
</script>
