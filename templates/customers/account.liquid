<section class="static-page">
  <div class="container static-narrow auth-page">
    <div class="section-header"><h1>My Account</h1></div>

    <p>Welcome back{% if customer.first_name != blank %}, {{ customer.first_name }}{% endif %}! <a href="/account/logout">Log out</a></p>
    <p><a href="/account/addresses">Manage addresses</a></p>

    <h3>Order History</h3>
    {% if customer.orders.size > 0 %}
      <table class="account-orders">
        <thead><tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
        <tbody>
          {% for order in customer.orders %}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: "%b %d, %Y" }}</td>
              <td>{{ order.total_price | money }}</td>
              <td>{{ order.financial_status }} / {{ order.fulfillment_status }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>You haven't placed any orders yet.</p>
    {% endif %}
  </div>
</section>
