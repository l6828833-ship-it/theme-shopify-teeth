<section class="static-page">
  <div class="container static-narrow auth-page">
    <div class="section-header"><h1>Your Addresses</h1></div>
    <p><a href="/account">← Back to my account</a></p>

    <h3>Add a new address</h3>
    {% form 'customer_address', customer.new_address %}
      {{ form.errors | default_errors }}
      <label>First name</label>
      <input type="text" name="address[first_name]" value="{{ form.first_name }}">
      <label>Last name</label>
      <input type="text" name="address[last_name]" value="{{ form.last_name }}">
      <label>Address</label>
      <input type="text" name="address[address1]" value="{{ form.address1 }}">
      <label>City</label>
      <input type="text" name="address[city]" value="{{ form.city }}">
      <label>Country</label>
      <input type="text" name="address[country]" value="{{ form.country }}">
      <label>Zip / Postal code</label>
      <input type="text" name="address[zip]" value="{{ form.zip }}">
      <button type="submit" class="cta-button">Add Address</button>
    {% endform %}

    {% if customer.addresses.size > 0 %}
      <h3>Saved addresses</h3>
      {% for address in customer.addresses %}
        <div class="saved-address">
          <p>{{ address.first_name }} {{ address.last_name }}<br>
          {{ address.address1 }}<br>
          {{ address.city }}, {{ address.country }} {{ address.zip }}</p>
        </div>
      {% endfor %}
    {% endif %}
  </div>
</section>
